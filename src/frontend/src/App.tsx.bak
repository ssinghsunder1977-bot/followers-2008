import { Toaster } from "@/components/ui/sonner";
import { AnimatePresence, motion } from "motion/react";
import { useEffect, useState } from "react";
import { toast } from "sonner";

const UPI_QR_IMAGE =
  "/assets/uploads/img-20260328-wa0003-019d324a-7d9b-70bf-903c-d9f5e9ba4fff-2.jpg";
const UPI_ID = "8700910551@ptsbi";
const UPI_NAME = "Sunder Singh";
const ADMIN_PASSWORD = "admin2008";
const ORDERS_KEY = "followers2008_orders";

type Order = {
  id: number;
  instagram: string;
  product: string;
  price: string;
  date: string;
  status: "pending" | "delivered";
};

const profiles = [
  { id: "women/43", username: "@influencer_jane", followers: "12.9k" },
  { id: "men/34", username: "@thetravelguy", followers: "24.5k" },
  { id: "women/65", username: "@fit_kim", followers: "37.1k" },
  { id: "men/16", username: "@john_style", followers: "8.7k" },
  { id: "men/28", username: "@foodie_pndt", followers: "15.3k" },
  { id: "women/55", username: "@artsy_anna", followers: "19.2k" },
];

type Plan = {
  title: string;
  amount: string;
  desc: string;
  price: string;
  tag?: string | null;
  productName: string;
  priceInPaise: number;
};

const pricingPlans: Plan[] = [
  {
    title: "Basic",
    amount: "100",
    desc: "Try it out",
    price: "\u20B9130",
    tag: null,
    productName: "Basic - 100 Instagram Followers",
    priceInPaise: 13000,
  },
  {
    title: "Starter",
    amount: "2,000",
    desc: "For growing creators",
    price: "\u20B9360",
    tag: "Popular",
    productName: "Starter - 2,000 Instagram Followers",
    priceInPaise: 36000,
  },
  {
    title: "Pro",
    amount: "10,000",
    desc: "Fuel your reach",
    price: "\u20B91,200",
    tag: "Best Value",
    productName: "Pro - 10,000 Instagram Followers",
    priceInPaise: 120000,
  },
  {
    title: "Influencer",
    amount: "5,00,000",
    desc: "Level up big time",
    price: "\u20B92,500",
    tag: null,
    productName: "Influencer - 5,00,000 Instagram Followers",
    priceInPaise: 250000,
  },
];

const likesViewsPlans: Plan[] = [
  {
    title: "1K Likes",
    amount: "1,000",
    desc: "Boost your post likes",
    price: "\u20B910",
    productName: "1,000 Instagram Likes",
    priceInPaise: 1000,
  },
  {
    title: "1K Views",
    amount: "1,000",
    desc: "Boost your video views",
    price: "\u20B910",
    productName: "1,000 Instagram Views",
    priceInPaise: 1000,
  },
];

export default function App() {
  const [loadingPlan, setLoadingPlan] = useState<string | null>(null);
  const [isAdmin, setIsAdmin] = useState(false);
  const [isAdminLoggedIn, setIsAdminLoggedIn] = useState(false);
  const [adminPassword, setAdminPassword] = useState("");
  const [adminPasswordError, setAdminPasswordError] = useState("");
  const [showPassword, setShowPassword] = useState(false);
  const [showInstagramModal, setShowInstagramModal] = useState(false);
  const [instagramHandle, setInstagramHandle] = useState("");
  const [pendingPlan, setPendingPlan] = useState<Plan | null>(null);
  const [showUpiModal, setShowUpiModal] = useState(false);
  const [orders, setOrders] = useState<Order[]>([]);

  useEffect(() => {
    if (window.location.pathname === "/admin") {
      setIsAdmin(true);
      if (sessionStorage.getItem("admin_auth") === "true") {
        setIsAdminLoggedIn(true);
        const stored = JSON.parse(localStorage.getItem(ORDERS_KEY) || "[]");
        setOrders(stored);
      }
    }
  }, []);

  const handleAdminLogin = () => {
    if (adminPassword === ADMIN_PASSWORD) {
      sessionStorage.setItem("admin_auth", "true");
      setIsAdminLoggedIn(true);
      setAdminPasswordError("");
      const stored = JSON.parse(localStorage.getItem(ORDERS_KEY) || "[]");
      setOrders(stored);
    } else {
      setAdminPasswordError("Wrong password. Try again.");
    }
  };

  const handleAdminLogout = () => {
    sessionStorage.removeItem("admin_auth");
    setIsAdminLoggedIn(false);
    setAdminPassword("");
    setAdminPasswordError("");
    setOrders([]);
  };

  const handleMarkDelivered = (id: number) => {
    const updated = orders.map((o) =>
      o.id === id ? { ...o, status: "delivered" as const } : o,
    );
    setOrders(updated);
    localStorage.setItem(ORDERS_KEY, JSON.stringify(updated));
    toast.success("Order marked as delivered!");
  };

  const handleClearOrders = () => {
    setOrders([]);
    localStorage.removeItem(ORDERS_KEY);
    toast.success("All orders cleared.");
  };

  const scrollTo = (id: string) => {
    document.getElementById(id)?.scrollIntoView({ behavior: "smooth" });
  };

  const handleBuyClick = (plan: Plan) => {
    setPendingPlan(plan);
    setInstagramHandle("");
    setShowInstagramModal(true);
  };

  const handleUpiPay = () => {
    if (!instagramHandle.trim()) {
      toast.error("Please enter your Instagram username.");
      return;
    }
    setShowInstagramModal(false);
    setLoadingPlan(null);

    // Save order to localStorage
    const existingOrders = JSON.parse(localStorage.getItem(ORDERS_KEY) || "[]");
    existingOrders.unshift({
      id: Date.now(),
      instagram: instagramHandle,
      product: pendingPlan?.productName || "",
      price: pendingPlan?.price || "",
      date: new Date().toLocaleDateString("en-IN"),
      status: "pending",
    });
    localStorage.setItem(ORDERS_KEY, JSON.stringify(existingOrders));

    setShowUpiModal(true);
  };

  const renderPlanCard = (plan: Plan, i: number, prefix: string) => {
    const isLoading = loadingPlan === plan.title;
    const isDisabled = !!loadingPlan;
    return (
      <motion.div
        key={plan.title}
        initial={{ opacity: 0, y: 24 }}
        whileInView={{ opacity: 1, y: 0 }}
        viewport={{ once: true }}
        transition={{ duration: 0.45, delay: i * 0.1 }}
        style={{
          background: "#fff",
          borderRadius: 16,
          boxShadow: "0 3px 24px rgba(37,99,235,0.09)",
          padding: "2rem 1.5rem",
          textAlign: "center",
          position: "relative",
        }}
        data-ocid={`${prefix}.item.${i + 1}`}
      >
        {plan.tag && (
          <span
            style={{
              position: "absolute",
              top: 18,
              right: 18,
              background: "linear-gradient(90deg, #2563eb, #60a5fa)",
              color: "#fff",
              fontSize: "0.8rem",
              padding: "2px 14px",
              borderRadius: 20,
              fontWeight: 700,
            }}
          >
            {plan.tag}
          </span>
        )}
        <div
          style={{
            fontSize: "1.18rem",
            color: "#222",
            marginBottom: "0.7rem",
            fontWeight: 700,
          }}
        >
          {plan.title}
        </div>
        <div
          style={{
            fontSize: "2.2rem",
            fontWeight: 800,
            marginBottom: "0.2rem",
            color: "#2563eb",
          }}
        >
          {plan.amount}
        </div>
        <div
          style={{
            fontSize: "1rem",
            color: "#6b7280",
            marginBottom: "1.2rem",
          }}
        >
          {plan.desc}
        </div>
        <button
          type="button"
          disabled={isDisabled}
          onClick={() => handleBuyClick(plan)}
          style={{
            marginTop: 10,
            padding: "0.8rem 2.2rem",
            background: isDisabled ? "#93c5fd" : "#2563eb",
            color: "#fff",
            border: "none",
            borderRadius: 40,
            fontSize: "1.1rem",
            fontWeight: 600,
            cursor: isDisabled ? "not-allowed" : "pointer",
            display: "inline-flex",
            alignItems: "center",
            gap: 8,
            transition: "background 0.2s",
            minWidth: 160,
            justifyContent: "center",
          }}
          onMouseEnter={(e) => {
            if (!isDisabled)
              (e.currentTarget as HTMLButtonElement).style.background =
                "#60a5fa";
          }}
          onMouseLeave={(e) => {
            if (!isDisabled)
              (e.currentTarget as HTMLButtonElement).style.background =
                "#2563eb";
          }}
          data-ocid={`${prefix}.primary_button.${i + 1}`}
        >
          {isLoading ? (
            <>
              <svg
                style={{
                  width: 18,
                  height: 18,
                  animation: "spin 1s linear infinite",
                }}
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                strokeWidth={2.5}
              >
                <title>Loading</title>
                <path
                  d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"
                  strokeLinecap="round"
                />
              </svg>
              Processing...
            </>
          ) : (
            <>Buy for {plan.price}</>
          )}
        </button>
      </motion.div>
    );
  };

  // Admin Page
  if (isAdmin) {
    // Login Screen
    if (!isAdminLoggedIn) {
      return (
        <div
          style={{
            minHeight: "100vh",
            background: "#f7fafc",
            fontFamily: "'Segoe UI', Arial, sans-serif",
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
          }}
        >
          <Toaster />
          <motion.div
            initial={{ opacity: 0, y: 24 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.45 }}
            style={{
              background: "#fff",
              borderRadius: 16,
              boxShadow: "0 4px 32px rgba(37,99,235,0.1)",
              padding: "2.5rem 2rem",
              maxWidth: 400,
              width: "100%",
              margin: "0 1rem",
            }}
          >
            <div style={{ textAlign: "center", marginBottom: "1.8rem" }}>
              <div
                style={{
                  width: 56,
                  height: 56,
                  background: "linear-gradient(135deg, #2563eb, #60a5fa)",
                  borderRadius: "50%",
                  display: "flex",
                  alignItems: "center",
                  justifyContent: "center",
                  margin: "0 auto 1rem",
                }}
              >
                <i
                  className="fas fa-lock"
                  style={{ color: "#fff", fontSize: "1.4rem" }}
                />
              </div>
              <h2
                style={{
                  color: "#2563eb",
                  fontWeight: 700,
                  fontSize: "1.6rem",
                  margin: 0,
                }}
              >
                Admin Login
              </h2>
              <p
                style={{
                  color: "#6b7280",
                  fontSize: "0.9rem",
                  marginTop: "0.5rem",
                }}
              >
                Enter your password to access the admin panel
              </p>
            </div>

            <div style={{ marginBottom: "1.2rem" }}>
              <div style={{ position: "relative" }}>
                <input
                  type={showPassword ? "text" : "password"}
                  placeholder="Enter password"
                  value={adminPassword}
                  onChange={(e) => {
                    setAdminPassword(e.target.value);
                    setAdminPasswordError("");
                  }}
                  onKeyDown={(e) => {
                    if (e.key === "Enter") handleAdminLogin();
                  }}
                  style={{
                    width: "100%",
                    padding: "0.85rem 3rem 0.85rem 1rem",
                    border: adminPasswordError
                      ? "1.5px solid #ef4444"
                      : "1.5px solid #d1d5db",
                    borderRadius: 8,
                    fontSize: "1rem",
                    boxSizing: "border-box",
                    outline: "none",
                    transition: "border-color 0.2s",
                  }}
                  data-ocid="admin.input"
                />
                <button
                  type="button"
                  onClick={() => setShowPassword((v) => !v)}
                  style={{
                    position: "absolute",
                    right: 10,
                    top: "50%",
                    transform: "translateY(-50%)",
                    background: "none",
                    border: "none",
                    cursor: "pointer",
                    fontSize: "1.15rem",
                    color: "#6b7280",
                    padding: "4px 6px",
                    lineHeight: 1,
                    userSelect: "none",
                  }}
                  tabIndex={-1}
                  aria-label={showPassword ? "Hide password" : "Show password"}
                >
                  {showPassword ? "🙈" : "👁"}
                </button>
              </div>
              {adminPasswordError && (
                <p
                  style={{
                    color: "#ef4444",
                    fontSize: "0.88rem",
                    marginTop: "0.5rem",
                    margin: "0.5rem 0 0",
                  }}
                  data-ocid="admin.error_state"
                >
                  {adminPasswordError}
                </p>
              )}
            </div>

            <button
              type="button"
              onClick={handleAdminLogin}
              style={{
                width: "100%",
                padding: "0.85rem",
                background: "linear-gradient(90deg, #2563eb, #60a5fa)",
                color: "#fff",
                border: "none",
                borderRadius: 8,
                fontSize: "1.05rem",
                fontWeight: 600,
                cursor: "pointer",
                transition: "opacity 0.2s",
              }}
              onMouseEnter={(e) => {
                (e.currentTarget as HTMLButtonElement).style.opacity = "0.9";
              }}
              onMouseLeave={(e) => {
                (e.currentTarget as HTMLButtonElement).style.opacity = "1";
              }}
              data-ocid="admin.submit_button"
            >
              Login
            </button>
          </motion.div>
        </div>
      );
    }

    // Admin Panel (logged in)
    return (
      <div
        style={{
          minHeight: "100vh",
          background: "#f7fafc",
          fontFamily: "'Segoe UI', Arial, sans-serif",
          padding: "2rem 1rem",
        }}
      >
        <Toaster />
        <div style={{ maxWidth: 900, margin: "0 auto" }}>
          {/* Header */}
          <div
            style={{
              background: "#fff",
              borderRadius: 16,
              boxShadow: "0 4px 32px rgba(37,99,235,0.1)",
              padding: "1.5rem 2rem",
              marginBottom: "1.5rem",
              display: "flex",
              alignItems: "center",
              justifyContent: "space-between",
              flexWrap: "wrap",
              gap: "1rem",
            }}
          >
            <div>
              <h2
                style={{
                  color: "#2563eb",
                  fontWeight: 700,
                  fontSize: "1.6rem",
                  margin: 0,
                }}
              >
                <i className="fab fa-instagram" style={{ marginRight: 8 }} />
                Admin Panel
              </h2>
              <p
                style={{
                  color: "#6b7280",
                  fontSize: "0.9rem",
                  margin: "0.3rem 0 0",
                }}
              >
                Followers 2008 — Order Management
              </p>
            </div>
            <div style={{ display: "flex", gap: 10, flexWrap: "wrap" }}>
              <button
                type="button"
                onClick={() => {
                  setIsAdmin(false);
                  window.history.pushState({}, "", "/");
                }}
                style={{
                  padding: "0.4rem 1rem",
                  background: "transparent",
                  color: "#6b7280",
                  border: "1.5px solid #d1d5db",
                  borderRadius: 8,
                  fontSize: "0.88rem",
                  fontWeight: 600,
                  cursor: "pointer",
                }}
                data-ocid="admin.secondary_button"
              >
                <i className="fas fa-home" style={{ marginRight: 6 }} />
                Back to Site
              </button>
              <button
                type="button"
                onClick={handleAdminLogout}
                style={{
                  padding: "0.4rem 1rem",
                  background: "transparent",
                  color: "#ef4444",
                  border: "1.5px solid #ef4444",
                  borderRadius: 8,
                  fontSize: "0.88rem",
                  fontWeight: 600,
                  cursor: "pointer",
                  display: "flex",
                  alignItems: "center",
                  gap: 6,
                }}
                data-ocid="admin.delete_button"
              >
                <i className="fas fa-sign-out-alt" />
                Logout
              </button>
            </div>
          </div>

          {/* Orders Panel */}
          <div
            style={{
              background: "#fff",
              borderRadius: 16,
              boxShadow: "0 4px 32px rgba(37,99,235,0.1)",
              padding: "1.5rem 2rem",
            }}
          >
            <div
              style={{
                display: "flex",
                alignItems: "center",
                justifyContent: "space-between",
                marginBottom: "1.2rem",
                flexWrap: "wrap",
                gap: "0.8rem",
              }}
            >
              <h3
                style={{
                  fontSize: "1.2rem",
                  fontWeight: 700,
                  color: "#1e3a5f",
                  margin: 0,
                }}
              >
                📦 Orders ({orders.length})
              </h3>
              {orders.length > 0 && (
                <button
                  type="button"
                  onClick={handleClearOrders}
                  style={{
                    padding: "0.4rem 1rem",
                    background: "#fef2f2",
                    color: "#ef4444",
                    border: "1.5px solid #fecaca",
                    borderRadius: 8,
                    fontSize: "0.85rem",
                    fontWeight: 600,
                    cursor: "pointer",
                  }}
                  data-ocid="admin.delete_button"
                >
                  <i className="fas fa-trash" style={{ marginRight: 5 }} />
                  Clear All
                </button>
              )}
            </div>

            {orders.length === 0 ? (
              <div
                style={{
                  textAlign: "center",
                  padding: "3rem 1rem",
                  color: "#9ca3af",
                }}
                data-ocid="admin.empty_state"
              >
                <div style={{ fontSize: "3rem", marginBottom: "0.8rem" }}>
                  📭
                </div>
                <div style={{ fontSize: "1.1rem", fontWeight: 600 }}>
                  No orders yet
                </div>
                <div style={{ fontSize: "0.9rem", marginTop: "0.4rem" }}>
                  Orders will appear here when customers pay via UPI.
                </div>
              </div>
            ) : (
              <div style={{ overflowX: "auto" }}>
                <table
                  style={{
                    width: "100%",
                    borderCollapse: "collapse",
                    fontSize: "0.92rem",
                  }}
                  data-ocid="admin.table"
                >
                  <thead>
                    <tr
                      style={{
                        background: "#eff6ff",
                        borderBottom: "2px solid #bfdbfe",
                      }}
                    >
                      {[
                        "#",
                        "Instagram",
                        "Product",
                        "Price",
                        "Date",
                        "Status",
                        "Action",
                      ].map((h) => (
                        <th
                          key={h}
                          style={{
                            padding: "0.7rem 0.9rem",
                            textAlign: "left",
                            color: "#2563eb",
                            fontWeight: 700,
                            whiteSpace: "nowrap",
                          }}
                        >
                          {h}
                        </th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {orders.map((order, i) => (
                      <tr
                        key={order.id}
                        style={{
                          borderBottom: "1px solid #f3f4f6",
                          background: i % 2 === 0 ? "#fff" : "#fafafa",
                        }}
                        data-ocid={`admin.row.${i + 1}`}
                      >
                        <td
                          style={{
                            padding: "0.7rem 0.9rem",
                            color: "#9ca3af",
                            fontWeight: 600,
                          }}
                        >
                          {i + 1}
                        </td>
                        <td
                          style={{
                            padding: "0.7rem 0.9rem",
                            fontWeight: 700,
                            color: "#2563eb",
                          }}
                        >
                          @{order.instagram}
                        </td>
                        <td
                          style={{
                            padding: "0.7rem 0.9rem",
                            color: "#374151",
                            maxWidth: 200,
                          }}
                        >
                          {order.product}
                        </td>
                        <td
                          style={{
                            padding: "0.7rem 0.9rem",
                            fontWeight: 700,
                            color: "#065f46",
                            whiteSpace: "nowrap",
                          }}
                        >
                          {order.price}
                        </td>
                        <td
                          style={{
                            padding: "0.7rem 0.9rem",
                            color: "#6b7280",
                            whiteSpace: "nowrap",
                          }}
                        >
                          {order.date}
                        </td>
                        <td style={{ padding: "0.7rem 0.9rem" }}>
                          <span
                            style={{
                              display: "inline-block",
                              padding: "3px 12px",
                              borderRadius: 20,
                              fontSize: "0.82rem",
                              fontWeight: 700,
                              background:
                                order.status === "delivered"
                                  ? "#dcfce7"
                                  : "#fef9c3",
                              color:
                                order.status === "delivered"
                                  ? "#166534"
                                  : "#92400e",
                              border:
                                order.status === "delivered"
                                  ? "1px solid #bbf7d0"
                                  : "1px solid #fde68a",
                            }}
                          >
                            {order.status === "delivered"
                              ? "✓ Delivered"
                              : "⏳ Pending"}
                          </span>
                        </td>
                        <td style={{ padding: "0.7rem 0.9rem" }}>
                          {order.status === "pending" && (
                            <button
                              type="button"
                              onClick={() => handleMarkDelivered(order.id)}
                              style={{
                                padding: "0.35rem 0.85rem",
                                background: "#2563eb",
                                color: "#fff",
                                border: "none",
                                borderRadius: 8,
                                fontSize: "0.82rem",
                                fontWeight: 600,
                                cursor: "pointer",
                                whiteSpace: "nowrap",
                              }}
                              data-ocid={`admin.save_button.${i + 1}`}
                            >
                              Mark Delivered
                            </button>
                          )}
                          {order.status === "delivered" && (
                            <span
                              style={{
                                color: "#16a34a",
                                fontSize: "0.85rem",
                                fontWeight: 600,
                              }}
                            >
                              ✓ Done
                            </span>
                          )}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        </div>
      </div>
    );
  }

  return (
    <div
      style={{
        minHeight: "100vh",
        background: "#f7fafc",
        fontFamily: "'Segoe UI', Arial, sans-serif",
        color: "#222",
      }}
    >
      <Toaster />

      {/* Instagram Handle Modal */}
      <AnimatePresence>
        {showInstagramModal && (
          <motion.div
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            style={{
              position: "fixed",
              inset: 0,
              background: "rgba(0,0,0,0.55)",
              zIndex: 1000,
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
              padding: "1rem",
            }}
            role="presentation"
            onClick={(e) => {
              if (e.target === e.currentTarget) setShowInstagramModal(false);
            }}
            onKeyDown={(e) => {
              if (e.key === "Escape") setShowInstagramModal(false);
            }}
            data-ocid="instagram.modal"
          >
            <motion.div
              initial={{ scale: 0.93, y: 20 }}
              animate={{ scale: 1, y: 0 }}
              exit={{ scale: 0.93, y: 20 }}
              transition={{ type: "spring", stiffness: 320, damping: 28 }}
              style={{
                background: "#fff",
                borderRadius: 20,
                padding: "2rem",
                maxWidth: 400,
                width: "100%",
                boxShadow: "0 12px 50px rgba(0,0,0,0.18)",
              }}
            >
              <h3
                style={{
                  color: "#2563eb",
                  marginBottom: "0.4rem",
                  fontWeight: 700,
                  fontSize: "1.3rem",
                }}
              >
                <i className="fab fa-instagram" style={{ marginRight: 8 }} />
                Enter Instagram Username
              </h3>
              <p
                style={{
                  color: "#6b7280",
                  fontSize: "0.9rem",
                  marginBottom: "1.2rem",
                }}
              >
                {pendingPlan?.productName} &mdash; {pendingPlan?.price}
              </p>
              <input
                type="text"
                placeholder="@your_instagram"
                value={instagramHandle}
                onChange={(e) => setInstagramHandle(e.target.value)}
                onKeyDown={(e) => {
                  if (e.key === "Enter") handleUpiPay();
                }}
                style={{
                  width: "100%",
                  padding: "0.75rem 1rem",
                  border: "1.5px solid #d1d5db",
                  borderRadius: 8,
                  fontSize: "1rem",
                  marginBottom: "1.2rem",
                  boxSizing: "border-box",
                  outline: "none",
                }}
                data-ocid="instagram.input"
              />

              <div
                style={{
                  display: "flex",
                  flexDirection: "column",
                  gap: 10,
                }}
              >
                <button
                  type="button"
                  onClick={handleUpiPay}
                  style={{
                    width: "100%",
                    padding: "0.85rem",
                    background: "linear-gradient(90deg, #00b9f1, #0070ba)",
                    color: "#fff",
                    border: "none",
                    borderRadius: 10,
                    fontSize: "1.05rem",
                    fontWeight: 600,
                    cursor: "pointer",
                    display: "flex",
                    alignItems: "center",
                    justifyContent: "center",
                    gap: 8,
                  }}
                  data-ocid="instagram.primary_button"
                >
                  <span style={{ fontSize: "1.2rem" }}>📱</span>
                  Pay {pendingPlan?.price} via UPI / Paytm
                </button>

                <button
                  type="button"
                  onClick={() => setShowInstagramModal(false)}
                  style={{
                    width: "100%",
                    padding: "0.7rem",
                    background: "transparent",
                    color: "#6b7280",
                    border: "1.5px solid #d1d5db",
                    borderRadius: 10,
                    fontSize: "0.95rem",
                    cursor: "pointer",
                  }}
                  data-ocid="instagram.cancel_button"
                >
                  Cancel
                </button>
              </div>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>

      {/* UPI QR Modal */}
      <AnimatePresence>
