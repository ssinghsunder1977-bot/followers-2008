            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            style={{
              position: "fixed",
              inset: 0,
              background: "rgba(0,0,0,0.65)",
              zIndex: 1100,
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
              padding: "1rem",
            }}
            role="presentation"
            onClick={(e) => {
              if (e.target === e.currentTarget) setShowUpiModal(false);
            }}
            onKeyDown={(e) => {
              if (e.key === "Escape") setShowUpiModal(false);
            }}
            data-ocid="upi.modal"
          >
            <motion.div
              initial={{ scale: 0.9, y: 30 }}
              animate={{ scale: 1, y: 0 }}
              exit={{ scale: 0.9, y: 30 }}
              transition={{ type: "spring", stiffness: 300, damping: 26 }}
              style={{
                background: "#fff",
                borderRadius: 24,
                padding: "2rem 1.8rem",
